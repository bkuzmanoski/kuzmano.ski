{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kuzmano-ski",
  "compatibility_date": "2026-07-19",
  "compatibility_flags": ["nodejs_compat"],
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS",
    "html_handling": "drop-trailing-slash"
  }
}
